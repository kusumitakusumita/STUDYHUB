# Copy this file to .env and fill in your own values before running the server.

# Port the API server listens on
PORT=4000

# Secret used to sign login tokens (JWTs). Use a long random string in production.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Allowed origin for the frontend (Vite's default dev server port)
CLIENT_ORIGIN=http://localhost:5173

# Optional: comma-separated names that should get admin-dashboard access
# the moment they register (in addition to whoever registers first, who
# always becomes an admin automatically). e.g.: ADMIN_NAMES=Professor Rao,TA Singh
ADMIN_NAMES=

# AWS S3 — required for file uploads (PDF, images, Word docs)
# 1. Create an IAM user in AWS Console with AmazonS3FullAccess policy
# 2. Generate an access key for that user
# 3. Create an S3 bucket and paste its name below
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=studyhub-uploads
